rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Election data — public read-only
    // Seeded by admins; no client writes allowed
    match /elections/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Polling place data — public read-only
    match /pollingPlaces/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // User checklist progress — authenticated users can only read/write their own data
    match /users/{userId}/checklist/{itemId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User profiles (future use) — authenticated users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
